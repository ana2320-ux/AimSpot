{
  "name": "aimspot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/backend",
    "src/frontend",
    "src/shared"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"bun run --cwd src/backend dev\" \"bun run --cwd src/frontend dev\"",
    "dev:backend": "bun run --cwd src/backend dev",
    "dev:frontend": "bun run --cwd src/frontend dev",
    "build": "bun run --cwd src/frontend build",
    "start": "bun run --cwd src/backend start"
  },
  
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
